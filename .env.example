# OpenAI API (for structured outputs, embeddings, Whisper post-MVP)
OPENAI_API_KEY=sk-...

# Anthropic API (for Claude tool-use agent)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily API (for web search - optional, enables historical context lookup)
TAVILY_API_KEY=tvly-...

# Mathpix API (post-MVP for STEM OCR)
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# OCR Settings (optional)
TESSERACT_CMD=/opt/homebrew/bin/tesseract
OCR_QUALITY_THRESHOLD=100
OCR_CHAR_DENSITY_THRESHOLD=0.5

# Premium OCR (disabled for MVP)
ENABLE_MATHPIX_OCR=false
ENABLE_CLAUDE_VISION_OCR=false

# Database paths (relative to project root)
DATABASE_PATH=data/app.db
CHROMA_PATH=data/chroma
UPLOAD_PATH=data/uploads

# Environment
FLASK_ENV=development
